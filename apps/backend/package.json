{
  "name": "@tsfullstack/backend",
  "type": "module",
  "scripts": {
    "prebuild": "zenstack generate",
    "predev": "zenstack generate",
    "zenstack:generate": "zenstack generate",
    "build": "tsdown --config tsdown.config.ts",
    "build:publish": "pnpm build:lib && pnpm --filter website-frontend build && pnpm build && pnpm publish:server",
    "publish:server": "bash ./publish.sh",
    "tsc:b": "tsc -b",
    "dev": "node dev.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "start:w": "node --enable-source-maps --watch ./dist/index.mjs",
    "build:lib": "tsdown --config tsdown-lib.config.ts",
    "build:lib:w": "tsdown --watch --config tsdown-lib.config.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:api": "tsx test/run-tests.ts",
    "test:manual": "tsx test/manual-test.ts",
    "build:projects": "tsx src/scripts/build-projects.ts"
  },
  "main": "./dist-lib/index.mjs",
  "types": "./dist-lib/index.d.mts",
  "files": [
    "dist-lib",
    "./src/lib/index.ts",
    "config.schema.json",
    "config.example.json",
    "CONFIG.md"
  ],
  "jsonSchema": {
    "config": "./config.schema.json"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@zenstackhq/orm": "^3.6.0",
    "@zenstackhq/plugin-policy": "^3.6.0",
    "@zenstackhq/schema": "^3.6.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "crypto-js": "^4.2.0",
    "effect": "^3.21.1",
    "fastify": "^5.8.5",
    "superjson": "^2.2.6",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@zenstackhq/cli": "^3.6.0",
    "tsdown": "^0.21.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}